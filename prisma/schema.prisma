generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id             String   @id @default(uuid())
  name           String
  videoName      String
  syncOffset     Float    @default(0.0)
  channelMapping String
  layoutConfig   String
  telemetryData  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
